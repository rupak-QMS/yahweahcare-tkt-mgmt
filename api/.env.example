# ============================================================
# Yahweahcare Backend — environment variables
# Copy to .env and adjust values
# ============================================================

# PostgreSQL connection string
DATABASE_URL=postgresql://localhost:5432/yahweahcare

# Port for the API server
PORT=4000

# JWT signing secret — CHANGE in production
JWT_SECRET=local-dev-secret-please-change

# CORS allowed origin
CORS_ORIGIN=*
