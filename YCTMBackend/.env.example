# ============================================================
# Yahwehcare HRMS — environment configuration
# Copy to .env (never commit secrets)
# ============================================================

# --- Server ---
NODE_ENV=development
PORT=4001
BACKEND_URL=http://localhost:4001
FRONTEND_URL=http://localhost:3000

# --- Database ---
DATABASE_URL=postgresql://localhost:5432/yahweahcare

# --- JWT (your application's own tokens) ---
JWT_SECRET=replace-with-a-32-byte-random-hex-string
SESSION_SECRET=replace-with-another-long-random-string
COOKIE_DOMAIN=localhost

# --- Microsoft Entra ID (Azure AD) ---
# From Azure Portal → Microsoft Entra ID → App registrations → <your app>
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_SECRET=replace-with-client-secret-value
# Single-tenant: use your tenant GUID. Multi-tenant: use "common" or "organizations"
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
# Must exactly match the URI registered in Azure
AZURE_REDIRECT_URI=http://localhost:4001/auth/microsoft/callback
AZURE_POST_LOGOUT_REDIRECT_URI=http://localhost:3000/auth/logged-out

# Microsoft Graph scopes to request
AZURE_SCOPES=openid profile email User.Read

# --- Org email validation ---
ALLOWED_EMAIL_DOMAINS=yahwehcare.com.au,yahwehpc.com.au

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
LOGIN_RATE_LIMIT_MAX=5
ACCOUNT_LOCK_THRESHOLD=5
ACCOUNT_LOCK_DURATION_MS=900000

# --- Session ---
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d
SESSION_INACTIVITY_TIMEOUT_MS=1800000

# --- Cookies ---
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# --- Web Push (VAPID) ---
# Generate keys with:  npm run generate-vapid
# Then add VAPID_PUBLIC_KEY + VAPID_PRIVATE_KEY to Vercel env vars (Settings → Environment Variables)
VAPID_PUBLIC_KEY=replace-with-public-key-from-npm-run-generate-vapid
VAPID_PRIVATE_KEY=replace-with-private-key-from-npm-run-generate-vapid
VAPID_SUBJECT=mailto:admin@yahwehcare.com.au

# --- Logging ---
LOG_LEVEL=info
