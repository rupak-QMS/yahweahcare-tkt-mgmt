{
  "name": "yahwehcare-hrms-auth",
  "version": "1.0.0",
  "description": "Enterprise HRMS authentication & authorization service — Microsoft Entra ID SSO, RBAC, audit logging",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "init-db": "ts-node src/db/init.ts",
    "seed": "ts-node src/db/seed.ts",
    "reset": "npm run init-db && npm run seed",
    "lint": "eslint 'src/**/*.ts'",
    "test": "jest"
  },
  "dependencies": {
    "@azure/msal-node": "^5.2.2",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@neondatabase/serverless": "^1.1.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^11.0.0",
    "@vercel/node": "^5.8.11",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.0.0",
    "isomorphic-fetch": "^3.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.11.0",
    "pg": "^8.21.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "uuid": "^14.0.0",
    "ws": "^8.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "ts-node-dev": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED",
  "private": true
}
