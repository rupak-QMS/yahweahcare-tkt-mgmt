{
  "name": "yahwehcare-hrms-auth",
  "version": "1.0.0",
  "description": "Enterprise HRMS authentication & authorization service — Microsoft Entra ID SSO, RBAC, audit logging",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "init-db": "ts-node src/db/init.ts",
    "seed": "ts-node src/db/seed.ts",
    "reset": "npm run init-db && npm run seed",
    "lint": "eslint 'src/**/*.ts'",
    "test": "jest"
  },
  "dependencies": {
    "@azure/msal-node": "^2.13.1",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@neondatabase/serverless": "^0.10.4",
    "@vercel/node": "^3.2.24",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "isomorphic-fetch": "^3.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.13.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "uuid": "^10.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.7.4",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0"
  },
  "devDependencies": {
    "ts-node-dev": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED",
  "private": true
}
