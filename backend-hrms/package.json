{
  "name": "yahwehcare-hrms-auth",
  "version": "1.0.0",
  "description": "Enterprise HRMS authentication & authorization service — Microsoft Entra ID SSO, RBAC, audit logging",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "init-db": "ts-node src/db/init.ts",
    "seed": "ts-node src/db/seed.ts",
    "reset": "npm run init-db && npm run seed",
    "generate-vapid": "node -e \"const wp=require('web-push');const k=wp.generateVAPIDKeys();console.log('\\nAdd these to Vercel → Settings → Environment Variables:\\n');console.log('VAPID_PUBLIC_KEY=' + k.publicKey);console.log('VAPID_PRIVATE_KEY=' + k.privateKey);console.log('VAPID_SUBJECT=mailto:admin@yahwehcare.com.au\\n');\"",
    "lint": "eslint 'src/**/*.ts'",
    "test": "jest"
  },
  "dependencies": {
    "@azure/msal-node": "^5.3.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@neondatabase/serverless": "^1.1.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "@vercel/node": "^5.8.22",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.0.0",
    "isomorphic-fetch": "^3.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.11.0",
    "pg": "^8.22.0",
    "resend": "^6.16.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "uuid": "^14.0.1",
    "web-push": "^3.6.7",
    "ws": "^8.18.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/supertest": "^7.2.0",
    "@types/web-push": "^3.3.3",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED",
  "private": true
}
